# Copy this file to .env and fill in your own API keys.
# Never commit the real .env file to GitHub.

# LLM provider configuration
MODEL_PROVIDER=openai
MODEL_NAME=gpt-4o-mini

# OpenAI API key
OPENAI_API_KEY=your_openai_api_key_here

# Groq API key, optional
GROQ_API_KEY=your_groq_api_key_here

# SEC requests should include a user agent.
# Replace this with your own name and email if needed.
SEC_USER_AGENT=InvestmentResearchAgent/0.1 contact@example.com

# Application environment
APP_ENV=development
